@inherits LayoutComponentBase
@using BilheteriaVirtualBlazor.Services
@inject AuthService AuthService
@inject NavigationManager Navigation
@implements IDisposable

<div id="app">
    @if (AuthService.EstaAutenticado())
    {
        <nav class="navbar">
            <div class="navbar-content">
                <a href="/" class="logo">🎫 Bilheteria Virtual</a>

                <ul class="nav-links">
                    <li><NavLink href="/" Match="NavLinkMatch.All">🎉 Eventos</NavLink></li>

                    @if (AuthService.EhCliente() || AuthService.EhAdmin())
                    {
                        <li><NavLink href="/comprar">🎫 Comprar</NavLink></li>
                        <li><NavLink href="/meus-ingressos">🎟️ Meus Ingressos</NavLink></li>
                    }

                    @if (AuthService.EhAdmin())
                    {
                        <li><NavLink href="/cadastrar">➕ Cadastrar</NavLink></li>
                        <li><NavLink href="/relatorios">📊 Relatórios</NavLink></li>
                    }
                </ul>

                <div class="user-menu">
                    <div class="user-avatar">@(AuthService.EhAdmin() ? "👨‍💼" : "👤")</div>
                    <div class="user-details">
                        <span class="user-name">@AuthService.ObterUsuarioLogado()?.Nome</span>
                        <span class="user-role">@(AuthService.EhAdmin() ? "Administrador" : "Cliente")</span>
                    </div>
                    <button class="btn-logout" @onclick="Logout" title="Sair">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                            <polyline points="16 17 21 12 16 7"/>
                            <line x1="21" y1="12" x2="9" y2="12"/>
                        </svg>
                        Sair
                    </button>
                </div>
            </div>
        </nav>

        <main class="page">
            @Body
        </main>
    }
    else
    {
        <main class="page">
            @Body
        </main>
    }
</div>

<style>
    .user-menu {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        padding: 0.375rem 0.75rem 0.375rem 0.375rem;
        background: var(--light);
        border-radius: 999px;
        border: 1px solid var(--border);
    }

    .user-avatar {
        width: 32px;
        height: 32px;
        background: var(--primary-light);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
    }

    .user-details {
        display: flex;
        flex-direction: column;
        line-height: 1.2;
    }

    .user-name {
        font-weight: 700;
        font-size: 0.82rem;
        color: var(--dark);
    }

    .user-role {
        font-size: 0.7rem;
        color: var(--gray);
        font-weight: 500;
    }

    .btn-logout {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        background: transparent;
        color: var(--gray);
        border: none;
        padding: 0.375rem 0.625rem;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.8rem;
        font-family: 'Inter', sans-serif;
        transition: all 0.2s;
        margin-left: 0.25rem;
    }

    .btn-logout:hover {
        background: var(--danger-light);
        color: var(--danger);
    }

    @@media (max-width: 768px) {
        .user-details { display: none; }
        .user-menu { padding: 0.375rem; }
    }
</style>

@code {
    protected override void OnInitialized()
    {
        AuthService.OnAuthStateChanged += StateHasChanged;

        if (!AuthService.EstaAutenticado() && !Navigation.Uri.Contains("/login"))
        {
            Navigation.NavigateTo("/login");
        }
    }

    private void Logout()
    {
        AuthService.Logout();
        Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        AuthService.OnAuthStateChanged -= StateHasChanged;
    }
}
