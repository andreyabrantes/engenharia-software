@page "/meus-ingressos"
@using BilheteriaVirtualBlazor.Services
@using BilheteriaVirtualBlazor.Models
@inject EventoService EventoService
@inject AuthService AuthService
@implements IDisposable

<PageTitle>Meus Ingressos - Bilheteria Virtual</PageTitle>

<div class="container">
    <div class="page-header">
        <div>
            <h1 class="page-title">🎟️ Meus Ingressos</h1>
            <p class="page-subtitle">Seus ingressos comprados</p>
        </div>
        @if (compras != null && compras.Any())
        {
            <span class="tickets-count">@compras.Count ingresso(s)</span>
        }
    </div>

    @if (compras == null || !compras.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">🎫</div>
            <h3>Nenhum ingresso ainda</h3>
            <p>Você ainda não comprou nenhum ingresso. Explore os eventos disponíveis!</p>
            <a href="/" class="btn btn-primary" style="margin-top:1.25rem; text-decoration:none">
                🎉 Ver Eventos
            </a>
        </div>
    }
    else
    {
        <div class="ingressos-list">
            @foreach (var compra in compras!.OrderByDescending(c => c.DataCompra))
            {
                <div class="ingresso-card">
                    <div class="ingresso-card-header">
                        <div class="ingresso-event-info">
                            <h3>@compra.EventoNome</h3>
                            <div class="ingresso-meta">
                                <span>📅 @compra.EventoData.ToString("dd/MM/yyyy HH:mm")</span>
                                <span>📍 @compra.EventoLocal</span>
                            </div>
                        </div>
                        <span class="badge-ativo">✓ Ativo</span>
                    </div>

                    <div class="ingresso-card-body">
                        <div class="ingresso-details">
                            <div class="detail-item">
                                <span class="detail-label">Setor</span>
                                <span class="detail-value">@compra.SetorNome</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Assentos</span>
                                <span class="detail-value">@string.Join(", ", compra.NumerosAssentos)</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Valor Pago</span>
                                <span class="detail-value price">@compra.ValorTotal.ToString("C2")</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Comprado em</span>
                                <span class="detail-value">@compra.DataCompra.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                        </div>

                        <div class="codigo-box">
                            <span class="codigo-label">Código de Acesso</span>
                            <span class="codigo-value">@compra.CodigoIngresso</span>
                            <span class="codigo-hint">Apresente na entrada do evento</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .page-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 1.5rem;
    }

    .page-title {
        font-size: 1.75rem;
        font-weight: 800;
        color: white;
        letter-spacing: -0.03em;
        margin-bottom: 0.25rem;
    }

    .page-subtitle { color: rgba(255,255,255,0.7); font-size: 0.9rem; }

    .tickets-count {
        background: rgba(255,255,255,0.15);
        color: white;
        padding: 0.375rem 0.875rem;
        border-radius: 999px;
        font-size: 0.82rem;
        font-weight: 700;
        backdrop-filter: blur(8px);
        border: 1px solid rgba(255,255,255,0.2);
    }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: rgba(255,255,255,0.8);
    }
    .empty-icon { font-size: 3.5rem; margin-bottom: 1rem; }
    .empty-state h3 { font-size: 1.2rem; font-weight: 700; margin-bottom: 0.5rem; color: white; }
    .empty-state p { font-size: 0.9rem; opacity: 0.7; }

    .ingressos-list { display: flex; flex-direction: column; gap: 1rem; }

    .ingresso-card {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 16px rgba(0,0,0,0.08);
        border: 1px solid var(--border);
        transition: transform 0.2s, box-shadow 0.2s;
        animation: fadeUp 0.4s ease-out;
    }
    .ingresso-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    }

    .ingresso-card-header {
        background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
        color: white;
        padding: 1.25rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
    }

    .ingresso-event-info h3 {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 0.375rem;
        letter-spacing: -0.01em;
    }

    .ingresso-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        font-size: 0.8rem;
        opacity: 0.9;
    }

    .badge-ativo {
        background: rgba(255,255,255,0.2);
        color: white;
        padding: 0.25rem 0.75rem;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 700;
        white-space: nowrap;
        border: 1px solid rgba(255,255,255,0.3);
        backdrop-filter: blur(4px);
    }

    .ingresso-card-body { padding: 1.25rem 1.5rem; }

    .ingresso-details {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 1rem;
        margin-bottom: 1.25rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid var(--border);
    }

    .detail-item { display: flex; flex-direction: column; gap: 0.2rem; }
    .detail-label {
        font-size: 0.7rem;
        color: var(--gray);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-weight: 700;
    }
    .detail-value { font-size: 0.9rem; font-weight: 600; color: var(--dark); }
    .detail-value.price { color: var(--primary); font-size: 1rem; font-weight: 800; }

    .codigo-box {
        background: var(--light);
        border-radius: 10px;
        padding: 1rem 1.25rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.3rem;
        border: 1.5px dashed var(--border);
    }

    .codigo-label {
        font-size: 0.7rem;
        color: var(--gray);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-weight: 700;
    }

    .codigo-value {
        font-size: 1.35rem;
        font-weight: 800;
        color: var(--primary);
        font-family: 'Courier New', monospace;
        letter-spacing: 0.12em;
    }

    .codigo-hint { font-size: 0.75rem; color: var(--gray); }
</style>

@code {
    private List<Compra>? compras;

    protected override void OnInitialized()
    {
        CarregarCompras();
        EventoService.OnEstadoAlterado += Atualizar;
    }

    private void Atualizar()
    {
        CarregarCompras();
        InvokeAsync(StateHasChanged);
    }

    private void CarregarCompras()
    {
        var email = AuthService.ObterUsuarioLogado()?.Email ?? "";
        compras = EventoService.ObterComprasPorEmail(email);
    }

    public void Dispose() => EventoService.OnEstadoAlterado -= Atualizar;
}
