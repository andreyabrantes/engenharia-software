@page "/"
@using BilheteriaVirtualBlazor.Services
@using BilheteriaVirtualBlazor.Models
@inject EventoService EventoService
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Eventos Disponíveis - Bilheteria Virtual</PageTitle>

<div class="container">
    <div class="card">
        <div class="card-header">
            <h1 class="card-title">🎉 Eventos Disponíveis</h1>
            <p class="card-subtitle">Escolha seu evento e garanta seu ingresso com segurança e comodidade!</p>
        </div>

        <div class="grid grid-3">
            @foreach (var evento in eventos)
            {
                var precoMinimo = evento.Setores.Min(s => s.Preco);
                
                <div class="event-card">
                    <div class="event-image">@evento.ImagemUrl</div>
                    <div class="event-content">
                        <h3 class="event-title">@evento.Nome</h3>
                        <div class="event-info">
                            📅 @evento.Data.ToString("dd/MM/yyyy HH:mm")<br/>
                            📍 @evento.Local<br/>
                            📝 @evento.Descricao
                        </div>
                        <div class="event-price">
                            A partir de @precoMinimo.ToString("C2")
                        </div>
                        
                        @if (AuthService.EhAdmin())
                        {
                            <div style="display: flex; gap: 0.5rem;">
                                <button class="btn btn-primary" @onclick="() => ComprarIngresso(evento.Id)" style="flex: 1;">
                                    Comprar Ingresso
                                </button>
                                <button class="btn btn-outline" @onclick="() => ExcluirEvento(evento.Id)" style="background: var(--danger); color: white; border: none;">
                                    🗑️
                                </button>
                            </div>
                        }
                        else
                        {
                            <button class="btn btn-primary" @onclick="() => ComprarIngresso(evento.Id)" style="width: 100%;">
                                Comprar Ingresso
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<Evento> eventos = new();

    protected override void OnInitialized()
    {
        CarregarEventos();
    }

    private void CarregarEventos()
    {
        eventos = EventoService.ObterEventos();
    }

    private void ComprarIngresso(int eventoId)
    {
        Navigation.NavigateTo($"/comprar?eventoId={eventoId}");
    }

    private void ExcluirEvento(int eventoId)
    {
        if (EventoService.ExcluirEvento(eventoId))
        {
            CarregarEventos();
            StateHasChanged();
        }
    }
}
